{
  "name": "@wa-chat/worker",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm --workspace @wa-chat/config run build && tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "start": "node dist/index.js",
    "typecheck": "npm --workspace @wa-chat/config run build && tsc --noEmit"
  },
  "dependencies": {
    "@wa-chat/config": "^0.0.1",
    "dotenv": "^16.6.1"
  }
}
